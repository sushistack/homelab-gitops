    {
      "id": "node-09-parse-rank",
      "name": "Parse Rank",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        300
      ],
      "parameters": {
        "jsCode": "const config = $('Set Config').first().json;\nconst MIN_SCORE = parseInt(config.MIN_SCORE) || 80;\nconst MAX_DAILY = parseInt(config.MAX_DAILY_CANDIDATES) || 1;\n\nif ($json.error) return []; // LLM HTTP error via continueOnFail\n\nconst content = ($json && $json.choices && $json.choices[0] && $json.choices[0].message && $json.choices[0].message.content) ? $json.choices[0].message.content : '';\n\nlet candidates;\ntry {\n  const cleaned = content.replace(/^\\uFEFF/, '').replace(/^```(?:json)?\\n?/, '').replace(/\\n?```$/, '').trim();\n  candidates = JSON.parse(cleaned);\n  if (!Array.isArray(candidates)) throw new Error('not an array');\n} catch (e) {\n  throw new Error('LLM non-JSON response: ' + e.message + ' | content: ' + content.slice(0, 200));\n}\n\nreturn candidates\n  .filter(c => (c.score || 0) >= MIN_SCORE && (c.expression || '').trim().length > 0)\n  .sort((a, b) => b.score - a.score)\n  .slice(0, MAX_DAILY)\n  .map(c => ({\n    json: {\n      sentence:       c.sentence || '',\n      expression:     c.expression || '',\n      korean:         c.korean_translation || '',\n      intuition:      c.intuition || '',\n      usageContext:   c.usage_context || '',\n      whyGood:        c.why_good || '',\n      score:          c.score || 0,\n      sourceTitle:    c.source_title || '',\n      sourceUrl:      c.source_url || '',\n      findNotesQuery: 'deck:' + JSON.stringify(config.TARGET_DECK) + ' Expression:' + JSON.stringify((c.expression || ''))\n    }\n  }));"
      }
    },
