    {
      "id": "node-07-build-prompt",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1260,
        300
      ],
      "parameters": {
        "jsCode": "const config = $('Set Config').first().json;\nconst entries = $json.entries || [];\n\nif (!entries.length) {\n  return [];\n}\n\nfunction stripHtml(html) {\n  return (html || '').replace(/<[^>]*>/g, '').replace(/\\s+/g, ' ').trim();\n}\n\nconst fetchLimit = parseInt(config.MINIFLUX_FETCH_LIMIT) || 30;\nconst snippets = entries.slice(0, fetchLimit).map(e => {\n  const title = (e.title || '').slice(0, 100);\n  const content = stripHtml(e.content || e.summary || '').slice(0, 300);\n  const url = e.url || '';\n  return 'TITLE: ' + title + '\\nURL: ' + url + '\\nCONTENT: ' + content;\n}).join('\\n\\n---\\n\\n');\n\nconst systemPrompt = [\n  'You are an English learning assistant. Extract sentences from articles worth memorizing for professional use.',\n  '',\n  'Output a JSON array ONLY \u2014 no markdown fences, no commentary, raw JSON. Each item:',\n  '{',\n  '  \"sentence\": \"full original sentence from the article\",',\n  '  \"expression\": \"key phrase or collocation (2-6 words)\",',\n  '  \"korean_translation\": \"Korean translation of the expression\",',\n  '  \"intuition\": \"why a native speaker uses this naturally (1 sentence)\",',\n  '  \"usage_context\": \"example using the expression in a different context\",',\n  '  \"why_good\": \"professional reuse value and native-sounding quality\",',\n  '  \"score\": 0,',\n  '  \"source_title\": \"article title\",',\n  '  \"source_url\": \"article URL\"',\n  '}',\n  '',\n  'Score 80+: broadly reusable in professional/technical writing, native-sounding collocation or idiom.',\n  'Reject: single words, overly academic jargon, domain-specific terms that only work in one field.'\n].join('\\n');\n\nreturn [{\n  json: {\n    model: config.LLM_MODEL,\n    messages: [\n      { role: 'system', content: systemPrompt },\n      { role: 'user', content: 'Extract learning candidates from these articles:\\n\\n' + snippets }\n    ]\n  }\n}];"
      }
    },
