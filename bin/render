#!/usr/bin/env python3
"""Render-time substitution: ${SECRET:NAME} -> real value from internal/tokens.env.

Writes ONLY under rendered/ (git-ignored). No tracked file ever holds a real value.
NB: ${SECRET:NAME} has a colon, so it is NOT valid `envsubst` syntax — hence this
literal substitution loop instead of bare envsubst.

Usage:  bin/render INPUT [INPUT ...]   # each INPUT -> rendered/INPUT
        bin/render --selftest
"""
import re
import sys
import pathlib

TOKENS = pathlib.Path("internal/tokens.env")
OUTDIR = pathlib.Path("rendered")
TOKEN_RE = re.compile(r"\$\{SECRET:([A-Z_]+)\}")
# Any ${SECRET:...} TOKEN_RE did NOT consume (bad NAME: lowercase/digit/hyphen) is a typo,
# not a real value — catch it instead of letting a literal token through to output.
STRAY_RE = re.compile(r"\$\{SECRET:[^}]*\}")


def load_tokens(path):
    vals = {}
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, _, v = line.partition("=")
        vals[k.strip()] = v.strip()
    return vals


def render(text, vals):
    missing = []

    def sub(m):
        name = m.group(1)
        if not vals.get(name):  # absent or empty
            missing.append(name)
            return m.group(0)
        return vals[name]

    return TOKEN_RE.sub(sub, text), missing


def dest_for(src):
    # Output MUST stay under rendered/ (git-ignored). An absolute INPUT or a `..` escape
    # would write a real-value file OUTSIDE the ignored dir — the exact leak this repo
    # exists to prevent. Resolve and check explicitly; never via assert (stripped under -O).
    dest = (OUTDIR / src).resolve()
    if src.is_absolute() or not dest.is_relative_to(OUTDIR.resolve()):
        sys.exit(f"{src}: INPUT must be a relative path that stays under {OUTDIR}/")
    return dest


def main(argv):
    if argv == ["--selftest"]:
        return selftest()
    if not argv:
        sys.exit(__doc__)
    if not TOKENS.exists():
        sys.exit(f"missing {TOKENS} — copy internal/tokens.example.env and fill real values")
    vals = load_tokens(TOKENS)
    for inp in argv:
        src = pathlib.Path(inp)
        dest = dest_for(src)  # validate the path BEFORE reading anything
        out, missing = render(src.read_text(), vals)
        if missing:
            sys.exit(f"{inp}: no value for {sorted(set(missing))}")
        stray = STRAY_RE.findall(out)
        if stray:
            sys.exit(f"{inp}: malformed token(s) (NAME must be [A-Z_]+): {sorted(set(stray))}")
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(out)
        print(dest)


def selftest():
    vals = {"HOST_PROXMOX": "real-host-01", "IP_LAN_GATEWAY": "10.x.x.x", "EMPTY": ""}
    out, missing = render("server ${SECRET:HOST_PROXMOX} gw ${SECRET:IP_LAN_GATEWAY}", vals)
    assert out == "server real-host-01 gw 10.x.x.x", out
    assert missing == [], missing
    # unfilled token is reported, not silently dropped
    _, missing = render("${SECRET:MISSING} ${SECRET:EMPTY}", vals)
    assert set(missing) == {"MISSING", "EMPTY"}, missing
    # colon syntax: a plain $VAR / ${VAR} (envsubst-style) is left untouched
    out, _ = render("$HOST_PROXMOX ${HOST_PROXMOX}", vals)
    assert out == "$HOST_PROXMOX ${HOST_PROXMOX}", out
    # a malformed token NAME (lowercase/digit/hyphen) is left literal -> STRAY_RE flags it
    out, _ = render("${SECRET:ip1} ${SECRET:HOST_PROXMOX}", vals)
    assert STRAY_RE.findall(out) == ["${SECRET:ip1}"], out
    # output path is forced under rendered/
    assert dest_for(pathlib.Path("infra/x.yaml")) == (OUTDIR / "infra/x.yaml").resolve()
    # absolute path and `..` escape are rejected, not written outside rendered/
    for bad in ["/etc/passwd", "../escape.yaml"]:
        try:
            dest_for(pathlib.Path(bad))
            assert False, f"escaped guard: {bad}"
        except SystemExit:
            pass
    print("selftest ok")


if __name__ == "__main__":
    main(sys.argv[1:])
