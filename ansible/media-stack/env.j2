# Rendered by deploy.yml into {{ deploy_dir }}/.env (mode 0600, no_log). docker compose auto-loads it.
# Non-secret knobs come from inventory group_vars; VPN secrets from secrets.sops.yaml (community.sops.load_vars).
TZ={{ TZ }}
PUID={{ PUID }}
PGID={{ PGID }}
HOST_DATA={{ HOST_DATA }}
HOST_CONFIG={{ HOST_CONFIG }}
VPN_SERVICE_PROVIDER={{ VPN_SERVICE_PROVIDER | default('') }}
VPN_TYPE={{ VPN_TYPE | default('') }}
WIREGUARD_PRIVATE_KEY={{ WIREGUARD_PRIVATE_KEY | default('') }}
WIREGUARD_ADDRESSES={{ WIREGUARD_ADDRESSES | default('') }}
SERVER_CITIES={{ SERVER_CITIES | default('') }}
