# Token declaration (placeholders only — COMMITTED).
#
# Copy to internal/tokens.env (git-ignored) and fill REAL values there.
# Tracked files reference these ONLY as ${SECRET:NAME}, e.g. ${SECRET:HOST_PROXMOX}.
# Render injects the real values into git-ignored output (see bin/render).
#
# Key enum: HOST_* (hostnames), IP_* (addresses), DOMAIN_* (domains). NAME is [A-Z0-9_]+.
# Leave every value blank here — real values never live in a tracked file.

HOST_PROXMOX=
IP_PROXMOX=
IP_LAN_GATEWAY=
# Phase 2a (Story 2.1): three k3s server nodes (embedded etcd). _A is the --cluster-init node.
IP_CLUSTER_NODE_A=
IP_CLUSTER_NODE_B=
IP_CLUSTER_NODE_C=
DOMAIN_PUBLIC=
DOMAIN_INTERNAL=
DOMAIN_DRAW=          # Story 1.4: full draw host (subdomain hidden too, not just the apex)
DOMAIN_NTFY=          # Story 4.1: full ntfy public host (single-label child of DOMAIN_PUBLIC)
DOMAIN_RSS=           # Story 4.6: full miniflux public host (rss.<public-zone>); IngressRoute + Certificate + BASE_URL
DOMAIN_KEEP=          # Story 4.5: full karakeep public host (keep.<public-zone> — NOT karakeep.*, Reconciliation 4); IngressRoute + Certificate
DOMAIN_VAULTWARDEN=   # Story 4.8: full vaultwarden public host (vault.<public-zone>); IngressRoute + Certificate + DOMAIN env
DOMAIN_N8N=           # Story 4.7: full n8n public host (n8n.<public-zone>); IngressRoute + Certificate + N8N_HOST/WEBHOOK_URL/N8N_BASE_URL
DOMAIN_KOMGA=         # Story 5.6: full komga PUBLIC host (live: comics.<public-zone>, NPM 16.conf no ACL); IngressRoute + Certificate + CF tunnel split + LAN override
DOMAIN_SUWAYOMI=      # Story 5.6: full Suwayomi INTERNAL-only host (live: comics-admin.<public-zone>, NPM 17.conf allow LAN+WG deny all); IngressRoute + Certificate, NO CF tunnel rule (LAN-only DNS override — ipAllowList would leak via the tunnel's LAN-IP egress)
DOMAIN_CALIBRE=       # Story 5.6: full calibre PUBLIC host (live: book.<public-zone> SINGULAR, NPM 20.conf no ACL); IngressRoute + Certificate + CF tunnel split + LAN override
DOMAIN_SEMAPHORE=     # Story 5.7: Semaphore INTERNAL-only host (semaphore.<internal-zone>); IngressRoute + Certificate, NO CF tunnel rule (LAN-only DNS override → 10.0.0.101)
DOMAIN_HEIMDALL=      # Story 5.7: Heimdall INTERNAL-only host (heimdall.<internal-zone>); IngressRoute + Certificate, NO CF tunnel rule (LAN-only DNS override → 10.0.0.101)
DOMAIN_BESZEL=        # Story 5.7: Beszel hub INTERNAL-only host (beszel.<internal-zone>); IngressRoute + Certificate, NO CF tunnel rule (LAN-only DNS override → 10.0.0.101)
DOMAIN_TRAEFIK=       # Traefik dashboard INTERNAL-only host (traefik.<internal-zone>); IngressRoute (api@internal) + Certificate, NO CF tunnel rule (LAN-only DNS override → 10.0.0.101)
DOMAIN_KUMA=          # Story 5.8 (AC6a): full uptime-kuma PUBLIC host (kuma.<public-zone>) — migrated INTO k3s; IngressRoute + Certificate + CF tunnel re-point + LAN override
# Story 5.8 (AC6b) — the five external hosts NPM fronted, now proxied by Traefik via headless
# Service + manual EndpointSlice -> external IP:port (workloads/edge-proxies). DOMAIN_* = public host
# (IngressRoute Host() + Certificate); IP_* = the backend the EndpointSlice points at. IP_PROXMOX
# already exists above. Backend PORTS live in workloads/edge-proxies/*-endpoints.yaml (confirm each
# against the live NPM nginx conf during cutover — see legacy-teardown.md).
DOMAIN_JELLYFIN=      # public host fronting the jellyfin LXC
DOMAIN_IMMICH=        # public host fronting the immich LXC
DOMAIN_PROXMOX=       # public host fronting the Proxmox UI (backend IP_PROXMOX:8006 https)
DOMAIN_OPENWRT=       # public host fronting the OpenWrt UI (backend IP_OPENWRT:443 https)
DOMAIN_KVM=           # public host fronting the NanoKVM UI (backend IP_KVM)
IP_JELLYFIN=          # jellyfin LXC address
IP_IMMICH=            # immich LXC address
IP_OPENWRT=           # OpenWrt gateway address (UI backend)
IP_KVM=               # NanoKVM address (.100 per memory nanokvm)
ACME_EMAIL=           # Story 1.5/2.4: ACME registration email for the letsencrypt-prod ClusterIssuer (PII — tokenized)

# NOT render tokens (never ${SECRET:*}) — operator ENV vars consumed directly by the playbook:
#   ARGOCD_REPO_TOKEN      (only if the GitOps repo is ever made private)
#   CLOUDFLARE_DNS01_TOKEN (Story 2.1 Task 2: injected as Secret cloudflare-dns01-token / ns
#                           cert-manager; scope Zone:DNS:Edit on the public zone only — NFR11)
