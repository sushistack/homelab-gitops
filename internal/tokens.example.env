# Token declaration (placeholders only — COMMITTED).
#
# Copy to internal/tokens.env (git-ignored) and fill REAL values there.
# Tracked files reference these ONLY as ${SECRET:NAME}, e.g. ${SECRET:HOST_PROXMOX}.
# Render injects the real values into git-ignored output (see bin/render).
#
# Key enum: HOST_* (hostnames), IP_* (addresses), DOMAIN_* (domains). NAME is [A-Z_]+.
# Leave every value blank here — real values never live in a tracked file.

HOST_PROXMOX=
HOST_CLUSTER_NODE=
IP_LAN_GATEWAY=
IP_CLUSTER_NODE=
IP_PROXMOX=
DOMAIN_PUBLIC=
DOMAIN_INTERNAL=
DOMAIN_DRAW=          # Story 1.4: full draw host (subdomain hidden too, not just the apex)
ACME_EMAIL=           # Story 1.5: ACME registration email for the LE-staging ClusterIssuer (PII — tokenized)
